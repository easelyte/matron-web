{
    "name": "matron-web",
    "version": "1.12.11-rc.0",
    "description": "A lightweight browser client for chatting with agents",
    "author": "Matron Contributors",
    "repository": {
        "type": "git",
        "url": "https://github.com/Matronhq/matron-web"
    },
    "license": "AGPL-3.0-only OR GPL-3.0-only",
    "type": "module",
    "scripts": {
        "build": "rimraf webapp && webpack --config webpack.config.mjs --mode production",
        "start": "webpack serve --config webpack.config.mjs --mode development",
        "lint": "pnpm lint:types && prettier --check src test webpack.config.mjs jest.config.cjs babel.config.cjs",
        "lint:fix": "prettier --write src test webpack.config.mjs jest.config.cjs babel.config.cjs",
        "lint:types": "tsc --noEmit",
        "test": "jest --runInBand",
        "coverage": "jest --runInBand --coverage"
    },
    "dependencies": {
        "@fontsource/fira-code": "^5.2.7",
        "@fontsource/inter": "^5.2.8",
        "hast-util-to-string": "^3",
        "highlight.js": "~11.11.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-markdown": "^9",
        "rehype-highlight": "^7",
        "remark-gfm": "^4"
    },
    "devDependencies": {
        "@babel/core": "^7.28.0",
        "@babel/preset-env": "^7.28.0",
        "@babel/preset-react": "^7.28.0",
        "@babel/preset-typescript": "^7.28.0",
        "@types/jest": "^30.0.0",
        "@types/node": "^22.0.0",
        "@types/react": "^19.2.10",
        "@types/react-dom": "^19.2.3",
        "babel-jest": "^30.0.0",
