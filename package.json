        "postcss-preset-env": "^11.1.0",
        "prettier": "^3.8.0",
        "rimraf": "^6.0.0",
        "typescript": "^5.9.3",
        "webpack": "^5.105.0",
        "webpack-cli": "^6.0.0",
        "webpack-dev-server": "^5.2.0"
